# Drizzle / Database
# Use a relative path so dev data stays inside the repo (./data)
DATABASE_PATH=./data/sqlite.db
# For production use this path
# DATABASE_PATH=/data/sqlite.db

# Auth
SESSION_SECRET=change-me-session-secret
PASSWORD_PEPPER=optional-extra-pepper

# Admin bootstrap
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=super-secret

# App
BASE_URL=http://localhost:3000
MAX_UPLOAD_MB=10

# Storage paths (adjust as needed)
# Keep these relative for dev (e.g. ./uploads) so nothing writes to /
UPLOADS_DIR=./uploads
POSTS_DIR=./posts
# For production use
# UPLOADS_DIR=/uploads
# POSTS_DIR=/posts
